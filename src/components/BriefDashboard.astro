---
type MarketMood = {
  label: string;
  summary: string;
};

type TopStory = {
  rank: number;
  cluster_id: string;
  headline_zh?: string;
  headline_zh_hant?: string;
  brief_reason_zh_hant?: string;
  heat_score?: number;
  categories?: string[];
  related_assets?: string[];
};

type SourceLink = {
  name?: string;
  source?: string;
  title: string;
  url: string;
  published_at?: string | null;
};

type Cluster = {
  cluster_id: string;
  headline_zh?: string;
  headline_zh_hant?: string;
  summary_zh_hant?: string;
  what_happened_zh_hant?: string;
  key_points_zh_hant?: string[];
  why_it_matters_zh_hant?: string;
  watch_next_zh_hant?: string;
  summary_type?: string;
  heat_score: number;
  heat_reasons: string[];
  categories: string[];
  related_markets?: string[];
  related_assets: string[];
  source_links?: SourceLink[];
  sources?: SourceLink[];
  source_count?: number;
  summary?: {
    what_happened: string;
    key_points: string[];
    why_it_matters: string;
    watch_next: string[];
  };
};

type SourceStatus = {
  source: string;
  status: string;
  articles_found?: number;
  article_count?: number;
};

type BriefData = {
  date: string;
  run_time_hkt?: string;
  archive_id?: string;
  generated_at: string;
  market_mood: MarketMood | string;
  market_mood_label_zh_hant?: string;
  morning_brief?: string;
  morning_brief_zh_hant?: string;
  top_five?: TopStory[];
  article_count?: number;
  source_count?: number;
  cluster_count?: number;
  stats?: {
    source_count: number;
    article_count: number;
    cluster_count: number;
    summarized_cluster_count?: number;
  };
  clusters?: Cluster[];
  source_status?: SourceStatus[];
};

const {
  brief,
  pageLabel = "Latest Brief",
  archiveHref,
  homeHref,
} = Astro.props as {
  brief: BriefData;
  pageLabel?: string;
  archiveHref?: string;
  homeHref?: string;
};

const categoryOrder = [
  "宏觀",
  "美股",
  "港股",
  "中概",
  "AI",
  "半導體",
  "科技公司",
  "加密",
  "外匯",
  "商品",
  "地緣政治",
  "企業財報",
];

const sortedClusters = [...(brief.clusters ?? [])].sort((a, b) => b.heat_score - a.heat_score);
const topStories = brief.top_five ?? [];
const sourceStatus = brief.source_status ?? [];
const categories = Array.from(new Set(sortedClusters.flatMap((cluster) => cluster.categories ?? []))).sort((a, b) => {
  const left = categoryOrder.indexOf(a);
  const right = categoryOrder.indexOf(b);
  if (left === -1 && right === -1) return a.localeCompare(b, "zh-Hant");
  if (left === -1) return 1;
  if (right === -1) return -1;
  return left - right;
});

const moodKey = typeof brief.market_mood === "string" ? brief.market_mood : "neutral";
const moodEnglish =
  {
    risk_on: "Risk-on",
    risk_off: "Risk-off",
    mixed: "Mixed",
    neutral: "Neutral",
  }[moodKey] ?? "Neutral";
const moodLabel =
  typeof brief.market_mood === "string"
    ? (brief.market_mood_label_zh_hant ?? moodEnglish)
    : brief.market_mood.label;
const moodSummary =
  typeof brief.market_mood === "string"
    ? (brief.market_mood_label_zh_hant ?? moodEnglish)
    : brief.market_mood.summary;
const morningBrief = brief.morning_brief_zh_hant ?? brief.morning_brief ?? "目前未有晨報摘要。";
const sourceCount = brief.stats?.source_count ?? brief.source_count ?? 0;
const articleCount = brief.stats?.article_count ?? brief.article_count ?? 0;
const clusterCount = brief.stats?.cluster_count ?? brief.cluster_count ?? sortedClusters.length;
const summarizedCount = brief.stats?.summarized_cluster_count ?? sortedClusters.filter((cluster) => cluster.summary_type !== "none").length;
const clusterSources = (cluster: Cluster) => cluster.source_links ?? cluster.sources ?? [];
const sourceName = (source: SourceLink) => source.source ?? source.name ?? "Source";
const clusterHeadline = (cluster: Cluster) => cluster.headline_zh_hant ?? cluster.headline_zh ?? "未有正式標題";
const storyHeadline = (story?: TopStory) => story?.headline_zh_hant ?? story?.headline_zh ?? "";
const storyReason = (story: TopStory) => story.brief_reason_zh_hant ?? story.categories?.slice(0, 2).join(" / ") ?? "";
const whatHappened = (cluster: Cluster) => cluster.what_happened_zh_hant ?? cluster.summary?.what_happened ?? cluster.summary_zh_hant ?? "目前公開資訊有限。";
const whyItMatters = (cluster: Cluster) => cluster.why_it_matters_zh_hant ?? cluster.summary?.why_it_matters ?? "目前公開資訊有限。";
const keyPoints = (cluster: Cluster) => cluster.key_points_zh_hant ?? cluster.summary?.key_points ?? [];
const watchNext = (cluster: Cluster) => {
  if (cluster.watch_next_zh_hant) return [cluster.watch_next_zh_hant];
  return cluster.summary?.watch_next ?? [];
};
const generatedTime = new Intl.DateTimeFormat("zh-HK", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "Asia/Hong_Kong",
}).format(new Date(brief.generated_at));
const runTimeLabel = brief.run_time_hkt ? `${brief.run_time_hkt.slice(0, 2)}:${brief.run_time_hkt.slice(2)} HKT` : null;
const sourceHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return "";
  }
};
const publishedLabel = (publishedAt?: string | null) => {
  if (!publishedAt) return "";
  const date = new Date(publishedAt);
  if (Number.isNaN(date.getTime())) return "";
  return new Intl.DateTimeFormat("zh-HK", {
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZone: "Asia/Hong_Kong",
  }).format(date);
};
const formatScore = (score: number | undefined) => Number(score ?? 0).toFixed(1);
const heatLabel = (score: number | undefined) => {
  const value = Number(score ?? 0);
  if (value >= 70) return "High";
  if (value >= 45) return "Elevated";
  if (value >= 25) return "Watch";
  return "Low";
};
const heatTone = (score: number | undefined) => {
  const value = Number(score ?? 0);
  if (value >= 70) return "high";
  if (value >= 45) return "elevated";
  if (value >= 25) return "watch";
  return "low";
};
const leadHeadline = storyHeadline(topStories[0]) || (sortedClusters[0] ? clusterHeadline(sortedClusters[0]) : "");
---

<main class="brief-shell">
  <header class="topbar">
    <a class="brand" href="/" aria-label="Tiny Dream News V2 home">
      <span class="brand-mark" aria-hidden="true">TD</span>
      <span>
        <strong>Tiny Dream News V2</strong>
        <small>Global Finance & Technology Morning Brief</small>
      </span>
    </a>

    <div class="topbar-meta" aria-label="Current brief metadata">
      <span>{pageLabel}</span>
      {runTimeLabel && <strong>{runTimeLabel}</strong>}
    </div>

    <nav class="top-actions" aria-label="Brief navigation">
      {homeHref && <a href={homeHref}>Latest</a>}
      {archiveHref && <a href={archiveHref}>Archive</a>}
    </nav>
  </header>

  <section class="command-center" aria-labelledby="brief-title">
    <div class="morning-panel">
      <div class="panel-kicker">
        <span>今日市場主線</span>
        <time datetime={brief.generated_at}>{generatedTime}</time>
      </div>
      <h1 id="brief-title">{leadHeadline || "Tiny Dream News V2"}</h1>
      <div class={`mood-card mood-${moodKey}`}>
        <div>
          <span class="mood-dot" aria-hidden="true"></span>
          <strong>{moodEnglish}</strong>
        </div>
        <p>{moodLabel}</p>
      </div>
      <p class="morning-copy">{morningBrief}</p>
    </div>

    <aside class="priority-panel" aria-labelledby="top-five-title">
      <div class="section-heading">
        <p>Priority Queue</p>
        <h2 id="top-five-title">Top 5 Stories</h2>
      </div>
      {topStories.length === 0 ? (
        <div class="empty-state compact">
          <p>暫時未有重點新聞。</p>
        </div>
      ) : (
        <ol class="priority-list">
          {topStories.map((story) => (
            <li>
              <a href={`#${story.cluster_id}`}>
                <span class="rank">{story.rank}</span>
                <span class="story-copy">
                  <strong>{storyHeadline(story)}</strong>
                  {storyReason(story) && <em>{storyReason(story)}</em>}
                  <span class="story-meta">
                    {story.heat_score != null && <b>{formatScore(story.heat_score)} heat</b>}
                    {story.categories?.slice(0, 2).map((category) => <small>{category}</small>)}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ol>
      )}
    </aside>
  </section>

  <section class="stats-strip" aria-label="Daily brief statistics">
    <div>
      <span>{sourceCount}</span>
      <p>Sources analyzed</p>
    </div>
    <div>
      <span>{articleCount}</span>
      <p>Articles fetched</p>
    </div>
    <div>
      <span>{clusterCount}</span>
      <p>Clusters generated</p>
    </div>
    <div>
      <span>{summarizedCount}</span>
      <p>AI summaries</p>
    </div>
  </section>

  <section class="market-tabs" aria-labelledby="filter-title">
    <div>
      <p class="eyebrow">Market Tabs</p>
      <h2 id="filter-title">Themes sorted by heat score</h2>
    </div>
    <div class="filter-controls" role="list" aria-label="Filter news cards by category">
      <button type="button" class="filter-button is-active" data-filter="all">全部</button>
      {categories.map((category) => (
        <button type="button" class="filter-button" data-filter={category}>{category}</button>
      ))}
    </div>
  </section>

  {sortedClusters.length === 0 ? (
    <section class="empty-state">
      <h2>暫時未有新聞主題</h2>
      <p>資料生成完成後，這裡會顯示按 heat score 排序的新聞主題卡。</p>
    </section>
  ) : (
    <section class="cluster-list" aria-live="polite">
      {sortedClusters.map((cluster) => (
        <article
          class="cluster-card"
          id={cluster.cluster_id}
          data-categories={(cluster.categories ?? []).join("|")}
        >
          <div class={`heat-rail heat-${heatTone(cluster.heat_score)}`}>
            <span>{formatScore(cluster.heat_score)}</span>
            <strong>{heatLabel(cluster.heat_score)}</strong>
            <p>Heat score</p>
          </div>

          <div class="cluster-body">
            <header class="cluster-header">
              <div class="cluster-title-block">
                <div class="tag-row">
                  {(cluster.categories ?? []).map((category) => <span>{category}</span>)}
                </div>
                <h2>{clusterHeadline(cluster)}</h2>
                {cluster.summary_zh_hant && <p class="cluster-summary">{cluster.summary_zh_hant}</p>}
              </div>
              <div class="source-count">
                <span>{cluster.source_count ?? clusterSources(cluster).length}</span>
                <p>sources</p>
              </div>
            </header>

            {(cluster.related_assets ?? []).length > 0 && (
              <div class="asset-row" aria-label="Related assets">
                {(cluster.related_assets ?? []).slice(0, 8).map((asset) => <span>{asset}</span>)}
              </div>
            )}

            <div class="summary-grid">
              <section>
                <h3>What happened</h3>
                <p>{whatHappened(cluster)}</p>
              </section>
              <section>
                <h3>Why it matters</h3>
                <p>{whyItMatters(cluster)}</p>
              </section>
            </div>

            <div class="detail-grid">
              {keyPoints(cluster).length > 0 && (
                <section>
                  <h3>Key points</h3>
                  <ul>
                    {keyPoints(cluster).slice(0, 4).map((point) => <li>{point}</li>)}
                  </ul>
                </section>
              )}
              {watchNext(cluster).length > 0 && (
                <section>
                  <h3>Watch next</h3>
                  <ul>
                    {watchNext(cluster).map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              )}
            </div>

            {(cluster.heat_reasons ?? []).length > 0 && (
              <div class="heat-reasons">
                <h3>Heat reasons</h3>
                <ul>
                  {(cluster.heat_reasons ?? []).slice(0, 3).map((reason) => <li>{reason}</li>)}
                </ul>
              </div>
            )}

            <div class="source-links">
              <h3>Main sources</h3>
              {clusterSources(cluster).length === 0 ? (
                <p class="source-empty">暫時未有來源連結。</p>
              ) : (
                <div>
                  {clusterSources(cluster).map((source) => (
                    <a href={source.url} target="_blank" rel="noreferrer">
                      <span>{sourceName(source)}</span>
                      <strong>{source.title}</strong>
                      <small>
                        {sourceHost(source.url)}
                        {publishedLabel(source.published_at) && ` · ${publishedLabel(source.published_at)}`}
                      </small>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </section>
  )}

  <section class="source-status" aria-labelledby="source-status-title">
    <div class="section-heading">
      <p>Source Health</p>
      <h2 id="source-status-title">MVP Sources</h2>
    </div>
    {sourceStatus.length === 0 ? (
      <div class="empty-state compact">
        <p>暫時未有來源狀態。</p>
      </div>
    ) : (
      <div class="source-status-grid">
        {sourceStatus.map((source) => (
          <div class={`source-status-item status-${source.status}`}>
            <strong>{source.source}</strong>
            <span>{source.article_count ?? source.articles_found ?? 0} articles</span>
          </div>
        ))}
      </div>
    )}
  </section>
</main>

<script>
  const filterButtons = Array.from(document.querySelectorAll(".filter-button"));
  const cards = Array.from(document.querySelectorAll(".cluster-card"));

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const filter = button.getAttribute("data-filter") || "all";

      filterButtons.forEach((item) => {
        item.classList.toggle("is-active", item === button);
      });

      cards.forEach((card) => {
        const categories = (card.getAttribute("data-categories") || "").split("|");
        const shouldShow = filter === "all" || categories.includes(filter);
        card.toggleAttribute("hidden", !shouldShow);
      });
    });
  });
</script>
